pipeline{
    agent any

    stages{

        stage("code"){
            steps{
                git branch: 'main', url: 'https://github.com/jyothiharsha21/docker-networking-project.git'
            }
        }

        stage("Build Image"){
            steps{
                sh '''
                docker build -t frontend-v1 ./frontend
                docker build -t backend-v1 ./backend
                '''
            }
        }

        stage("Tag & Push"){
            steps{
                script{

                    sh '''
                    docker tag frontend-v1 jyothiharsha05/three-tier:frontend-v1
                    docker tag backend-v1 jyothiharsha05/three-tier:backend-v1
                    '''

                    docker.withRegistry('https://index.docker.io/v1/', 'dockerhub_id'){

                        sh '''
                        docker push jyothiharsha05/three-tier:frontend-v1
                        docker push jyothiharsha05/three-tier:backend-v1
                        '''

                    }
                }
            }
        }

        stage("Create Networks"){
            steps{
                sh '''
                docker network create frontend-network || true
                docker network create backend-network || true
                '''
            }
        }

        stage("Connect Database"){
            steps{
                sh '''
                docker rm -f mysql || true

                docker run -d \
                --name mysql \
                --network backend-network \
                -e MYSQL_ROOT_PASSWORD=root123 \
                -v $(pwd)/database/init.sql:/docker-entrypoint-initdb.d/init.sql \
                mysql:8
                '''
            }
        }

        stage("Run Backend"){
            steps{
                sh '''
                docker rm -f cont-2 || true

                docker run -itd \
                --name cont-2 \
                --network backend-network \
                -e DB_HOST=mysql \
                -e DB_USER=root \
                -e DB_PASSWORD=root123 \
                -e DB_NAME=company \
                -p 2222:5000 \
                jyothiharsha05/three-tier:backend-v1

                docker network connect frontend-network cont-2
                '''
            }
        }

        stage("Run Frontend"){
            steps{
                sh '''
                docker rm -f cont-1 || true

                docker run -itd \
                --name cont-1 \
                --network frontend-network \
                -p 1111:80 \
                jyothiharsha05/three-tier:frontend-v1
                '''
            }
        }

    }
}
